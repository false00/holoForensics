{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "pwsh -NoLogo -NoProfile -File .github/hooks/validate-git-doc-sync.ps1",
        "windows": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File .github/hooks/validate-git-doc-sync.ps1",
        "cwd": ".",
        "timeout": 900
      }
    ]
  }
}