import { ThemeTokens } from "../theme.slint";
import { Badge, CardPanel, CodexBand, GhostButton, HelperText, InfoLine, MiniModeButton, PrimaryButton, ProgressBar, ReadOnlyField, SectionLabel } from "../components.slint";
import { ParseArtifactItem } from "../models.slint";
import { ScrollView } from "std-widgets.slint";

component ParsePlanRow inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> detail;
    in property <string> status;
    in property <bool> selected: false;
    in property <bool> active: false;
    in property <int> tone: 0;
    in property <bool> enabled: true;
    in property <bool> dense: false;
    callback toggled();

    private property <color> accent-color: root.tone == 5 ? ThemeTokens.risk : root.tone == 4 ? ThemeTokens.success : root.tone == 3 ? (ThemeTokens.dark ? ThemeTokens.primary-hover : ThemeTokens.primary) : root.tone == 2 ? ThemeTokens.warning : root.tone == 1 ? ThemeTokens.primary.with-alpha(0.82) : ThemeTokens.stroke;

    height: root.dense ? 74px : 92px;
    border-radius: ThemeTokens.radius-large;
    border-width: 1px;
    border-color: root.active ? root.accent-color.with-alpha(0.72) : root.selected ? ThemeTokens.primary.with-alpha(0.42) : ThemeTokens.stroke;
    background: touch.enabled && touch.has-hover ? ThemeTokens.accent-soft : root.active ? ThemeTokens.accent-soft.with-alpha(0.72) : ThemeTokens.card;
    clip: true;
    animate background { duration: 100ms; }
    animate border-color { duration: 100ms; }

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: root.dense ? 12px : 14px;
        padding-right: root.dense ? 12px : 14px;
        padding-top: root.dense ? 10px : 12px;
        padding-bottom: root.dense ? 10px : 12px;
        spacing: root.dense ? 10px : 12px;

        Rectangle {
            width: root.dense ? 20px : 22px;
            height: root.dense ? 20px : 22px;
            y: root.dense ? 2px : 4px;
            border-radius: 6px;
            border-width: 1px;
            border-color: root.selected ? ThemeTokens.primary : ThemeTokens.stroke;
            background: root.selected ? ThemeTokens.primary : ThemeTokens.panel;

            Path {
                visible: root.selected;
                x: root.dense ? 5px : 6px;
                y: root.dense ? 5px : 6px;
                width: 10px;
                height: 10px;
                viewbox-x: 0;
                viewbox-y: 0;
                viewbox-width: 10;
                viewbox-height: 10;
                stroke: #FFFFFF;
                stroke-width: 1.6px;
                fill: transparent;
                commands: "M 1 5 L 4 8 L 9 1";
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: root.dense ? 3px : 5px;

            Text {
                horizontal-stretch: 1;
                text: root.title;
                color: ThemeTokens.text;
                font-family: "Figtree";
                font-size: root.dense ? 12px : 13px;
                font-weight: 500;
                overflow: elide;
            }

            Text {
                horizontal-stretch: 1;
                text: root.subtitle;
                color: ThemeTokens.muted;
                font-family: "Figtree";
                font-size: root.dense ? 10px : 11px;
                font-weight: 400;
                overflow: elide;
            }

            Text {
                horizontal-stretch: 1;
                text: root.detail;
                height: root.dense ? 0px : 28px;
                color: ThemeTokens.placeholder;
                font-family: "Figtree";
                font-size: 11px;
                font-weight: 400;
                wrap: word-wrap;
                overflow: elide;
                visible: !root.dense;
            }
        }

        Rectangle {
            width: root.dense ? 84px : 92px;
            height: root.dense ? 24px : 28px;
            y: root.dense ? 0px : 2px;
            border-radius: root.dense ? 12px : 14px;
            border-width: 1px;
            border-color: root.accent-color.with-alpha(0.46);
            background: root.accent-color.with-alpha(0.14);

            Text {
                width: parent.width;
                height: parent.height;
                text: root.status;
                color: root.accent-color;
                font-family: "Figtree";
                font-size: root.dense ? 10px : 11px;
                font-weight: 500;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        clicked => { root.toggled(); }
    }
}

component ParseStatusInfoRow inherits Rectangle {
    in property <string> label;
    in property <string> value;

    height: 38px;
    clip: true;
    border-radius: ThemeTokens.radius-small;
    border-width: 1px;
    border-color: ThemeTokens.stroke;
    background: ThemeTokens.card;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 9px;
        padding-right: 9px;
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 3px;

        SectionLabel {
            horizontal-stretch: 1;
            text: root.label;
        }

        InfoLine {
            horizontal-stretch: 1;
            text: root.value;
        }
    }
}

component ParseStatusDetailPanel inherits Rectangle {
    in property <string> phase;
    in property <string> current-status;
    in property <string> summary;
    in property <float> progress-value: 0;
    in property <string> coverage;

    clip: true;
    border-radius: ThemeTokens.radius-medium;
    border-width: 1px;
    border-color: ThemeTokens.stroke;
    background: ThemeTokens.panel;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: 10px;
        spacing: 7px;

        HorizontalLayout {
            height: 18px;
            spacing: 8px;

            Text {
                horizontal-stretch: 1;
                text: "Parser / Info";
                color: ThemeTokens.text;
                font-family: "Figtree";
                font-size: 13px;
                font-weight: 500;
                vertical-alignment: center;
                overflow: elide;
            }

            Text {
                width: 78px;
                text: root.phase;
                color: ThemeTokens.muted;
                font-family: "Figtree";
                font-size: 11px;
                font-weight: 500;
                horizontal-alignment: right;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        HelperText {
            horizontal-stretch: 1;
            height: 24px;
            text: root.summary == "" ? "Inspect a collection zip to preview parser plans, or parse immediately with full supported coverage." : root.summary;
        }

        ProgressBar {
            horizontal-stretch: 1;
            height: 8px;
            value: root.progress-value;
            fill: ThemeTokens.primary;
            track: ThemeTokens.surface;
        }

        ParseStatusInfoRow {
            horizontal-stretch: 1;
            label: "CURRENT";
            value: root.current-status == "" ? "Ready to parse a collection zip." : root.current-status;
        }

        ParseStatusInfoRow {
            horizontal-stretch: 1;
            label: "PLAN VIEW";
            value: root.coverage;
        }
    }
}

component ResourceMetricCard inherits Rectangle {
    in property <string> label;
    in property <string> detail;
    in property <float> value: 0;
    in property <float> target: 0.8;
    in property <color> accent: ThemeTokens.primary;

    height: 88px;
    border-radius: ThemeTokens.radius-medium;
    border-width: 1px;
    border-color: ThemeTokens.stroke;
    background: ThemeTokens.card;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 7px;
        padding-bottom: 7px;
        spacing: 4px;

        Text {
            horizontal-stretch: 1;
            height: 16px;
            text: root.label;
            color: ThemeTokens.text;
            font-family: "Figtree";
            font-size: 12px;
            font-weight: 500;
            overflow: elide;
        }

        Text {
            horizontal-stretch: 1;
            height: 24px;
            text: root.detail;
            color: ThemeTokens.muted;
            font-family: "Figtree";
            font-size: 11px;
            font-weight: 400;
            wrap: word-wrap;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: 10px;
            border-radius: 5px;
            background: ThemeTokens.surface;

            Rectangle {
                width: max(0px, parent.width * min(1.0, max(0.0, root.value)));
                height: parent.height;
                border-radius: 5px;
                background: root.accent;
                animate width { duration: 240ms; }
            }

            Rectangle {
                x: max(0px, min(parent.width - 2px, parent.width * min(1.0, max(0.0, root.target))));
                y: -3px;
                width: 2px;
                height: parent.height + 6px;
                border-radius: 1px;
                background: ThemeTokens.warning.with-alpha(0.92);
            }
        }
    }
}

component ParseResourcePanel inherits Rectangle {
    in property <float> cpu-value: 0;
    in property <float> memory-value: 0;
    in property <float> io-value: 0;
    in property <string> cpu-detail;
    in property <string> memory-detail;
    in property <string> io-detail;
    in property <string> status-text;
    in property <[string]> io-targets;
    in-out property <int> io-target-index: 0;
    in property <bool> busy: false;

    clip: true;
    border-radius: ThemeTokens.radius-medium;
    border-width: 1px;
    border-color: ThemeTokens.stroke;
    background: ThemeTokens.panel;

    private property <bool> io-target-clickable: root.io-targets.length > 1;
    private property <string> io-target-label: root.io-target-index >= 0 && root.io-target-index < root.io-targets.length ? root.io-targets[root.io-target-index] : "All drives";

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: 8px;
        spacing: 5px;

        HorizontalLayout {
            height: 18px;
            spacing: 8px;

            Text {
                horizontal-stretch: 1;
                text: "Adaptive Budget";
                color: ThemeTokens.text;
                font-family: "Tomorrow";
                font-size: 18px;
                font-weight: 300;
                vertical-alignment: center;
                overflow: elide;
            }

            Badge {
                width: 128px;
                label: root.busy ? "PROGRAM ACTIVE" : "READY TO PARSE";
            }
        }

        HelperText {
            horizontal-stretch: 1;
            height: 32px;
            text: root.status-text == "" ? "System-wide CPU, memory, and selected drive throughput stay live during offline parsing." : root.status-text;
        }

        HorizontalLayout {
            height: 88px;
            spacing: 8px;

            ResourceMetricCard {
                horizontal-stretch: 1;
                label: "CPU";
                detail: root.cpu-detail;
                value: root.cpu-value;
                accent: ThemeTokens.primary;
            }

            ResourceMetricCard {
                horizontal-stretch: 1;
                label: "Memory";
                detail: root.memory-detail;
                value: root.memory-value;
                accent: ThemeTokens.copal;
            }

            Rectangle {
                horizontal-stretch: 1;
                height: 88px;
                border-radius: ThemeTokens.radius-medium;
                border-width: 1px;
                border-color: ThemeTokens.stroke;
                background: ThemeTokens.card;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding-left: 10px;
                    padding-right: 10px;
                    padding-top: 7px;
                    padding-bottom: 7px;
                    spacing: 4px;

                    HorizontalLayout {
                        height: 38px;
                        spacing: 8px;

                        Text {
                            width: 24px;
                            height: parent.height;
                            text: "I/O";
                            color: ThemeTokens.text;
                            font-family: "Figtree";
                            font-size: 12px;
                            font-weight: 500;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: parent.height;
                            border-radius: ThemeTokens.radius-medium;
                            border-width: 1px;
                            border-color: io-target-touch.has-hover && root.io-target-clickable ? ThemeTokens.primary.with-alpha(0.48) : ThemeTokens.stroke;
                            background: io-target-touch.has-hover && root.io-target-clickable ? ThemeTokens.accent-soft : ThemeTokens.surface;
                            opacity: root.io-target-clickable ? 1 : 0.72;
                            animate background { duration: 100ms; }
                            animate border-color { duration: 100ms; }

                            HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                padding-left: 12px;
                                padding-right: 10px;
                                spacing: 8px;

                                Text {
                                    horizontal-stretch: 1;
                                    text: root.io-target-label;
                                    color: ThemeTokens.text;
                                    font-family: "Figtree";
                                    font-size: 13px;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }

                                Text {
                                    text: root.io-target-clickable ? "Click to cycle" : "Fixed";
                                    color: ThemeTokens.muted;
                                    font-family: "Figtree";
                                    font-size: 10px;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                }

                                Path {
                                    width: 10px;
                                    height: 10px;
                                    viewbox-x: 0;
                                    viewbox-y: 0;
                                    viewbox-width: 10;
                                    viewbox-height: 10;
                                    stroke: root.io-target-clickable ? ThemeTokens.primary : ThemeTokens.muted;
                                    stroke-width: 1.4px;
                                    fill: transparent;
                                    commands: "M 1 5 L 9 5 M 6 2 L 9 5 L 6 8";
                                }
                            }

                            io-target-touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                enabled: root.io-target-clickable;
                                clicked => {
                                    if root.io-targets.length > 1 {
                                        root.io-target-index = root.io-target-index + 1 >= root.io-targets.length ? 0 : root.io-target-index + 1;
                                    }
                                }
                            }
                        }
                    }

                    Text {
                        horizontal-stretch: 1;
                        height: 18px;
                        text: root.io-detail;
                        color: ThemeTokens.muted;
                        font-family: "Figtree";
                        font-size: 11px;
                        font-weight: 400;
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 10px;
                        border-radius: 5px;
                        background: ThemeTokens.surface;

                        Rectangle {
                            width: max(0px, parent.width * min(1.0, max(0.0, root.io-value)));
                            height: parent.height;
                            border-radius: 5px;
                            background: ThemeTokens.risk;
                            animate width { duration: 240ms; }
                        }
                    }
                }
            }
        }
    }
}

export component ParsePage inherits Rectangle {
    in property <int> active-page: 1;
    in-out property <bool> console-expanded: false;
    in property <bool> mode-switch-pulse: false;
    in property <string> collection-host-platform;
    in property <string> collection-host-hardware;
    in property <string> parse-archive-path;
    in property <string> parse-output-path;
    in property <bool> parse-inspecting: false;
    in property <bool> parse-running: false;
    in property <float> parse-progress-value: 0;
    in property <string> parse-status;
    in property <string> parse-summary;
    in property <string> parse-log;
    in property <[ParseArtifactItem]> detected-artifacts;
    in property <float> parse-resource-cpu-value: 0;
    in property <float> parse-resource-memory-value: 0;
    in property <float> parse-resource-io-value: 0;
    in property <string> parse-resource-cpu-detail;
    in property <string> parse-resource-memory-detail;
    in property <string> parse-resource-io-detail;
    in property <[string]> parse-resource-io-targets;
    in-out property <int> parse-resource-io-target-index: 0;
    in-out property <length> page-viewport-y: 0px;

    callback open-settings-requested();
    callback open-about-requested();
    callback switch-page-requested(int);
    callback browse-parse-archive-requested();
    callback browse-parse-output-requested();
    callback inspect-archive-requested();
    callback toggle-detected-artifact(int);
    callback run-parse-requested();

    private property <bool> compact-layout: self.width < 620px;
    private property <bool> short-layout: self.height < 760px;
    private property <length> page-padding: root.compact-layout ? 12px : 14px;
    private property <length> page-spacing: root.compact-layout ? 6px : 8px;
    private property <length> header-card-height: root.compact-layout ? 102px : 84px;
    private property <length> header-mode-row-y: root.compact-layout ? 14px : 8px;
    private property <length> header-action-row-y: (root.header-card-height - 38px) / 2;
    private property <length> resource-card-height: root.compact-layout ? 176px : 164px;
    private property <length> setup-card-height: root.compact-layout ? 214px : root.short-layout ? 188px : 196px;
    private property <bool> has-detected-artifacts: root.detected-artifacts.length > 0;
    private property <length> tail-height: max(0px, root.height - (root.page-padding * 2) - (root.page-spacing * 4) - root.header-card-height - root.resource-card-height - root.setup-card-height);
    private property <length> status-max-height: root.has-detected-artifacts ? (root.compact-layout ? 360px : 318px) : (root.compact-layout ? 220px : 196px);
    private property <length> status-min-height: root.has-detected-artifacts ? (root.compact-layout ? 144px : 136px) : (root.compact-layout ? 116px : 104px);
    private property <length> status-detail-min-width: 280px;
    private property <length> status-master-min-width: 280px;
    private property <length> status-split-handle-width: 12px;
    private property <length> parse-detail-width: 336px;
    private property <length> status-split-drag-start-width: 336px;
    private property <length> status-split-drag-start-pointer-x: 0px;
    private property <length> console-collapsed-height: 54px;
    private property <length> console-min-expanded-height: 104px;
    private property <length> console-card-height: root.console-expanded ? max(root.console-min-expanded-height, root.tail-height - root.status-max-height) : root.console-collapsed-height;
    private property <length> status-card-height: max(root.status-min-height, root.tail-height - root.console-card-height);
    private property <int> detected-plan-column-count: root.compact-layout ? 1 : 2;
    private property <bool> busy: root.parse-inspecting || root.parse-running;

    background: ThemeTokens.base;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: ThemeTokens.base;
    }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 4px;
        height: parent.height;
        background: ThemeTokens.primary.with-alpha(0.20);
    }

    Rectangle {
        x: 4px;
        y: 38px;
        width: 3px;
        height: max(80px, parent.height * 0.28);
        background: ThemeTokens.risk.with-alpha(0.22);
    }

    Rectangle {
        x: parent.width - 6px;
        y: max(80px, parent.height * 0.16);
        width: 3px;
        height: max(80px, parent.height * 0.24);
        background: ThemeTokens.copal.with-alpha(0.18);
    }

    Rectangle {
        x: parent.width - 4px;
        y: 0px;
        width: 4px;
        height: parent.height;
        background: ThemeTokens.carmine.with-alpha(0.10);
    }

    page-content := VerticalLayout {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            padding: root.page-padding;
            spacing: root.page-spacing;

            CardPanel {
                horizontal-stretch: 1;
                height: root.header-card-height;
                background: ThemeTokens.hero;
                clip: true;

                CodexBand {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: 6px;
                    compact: root.compact-layout;
                }

                Rectangle {
                    x: parent.width - (root.compact-layout ? 146px : 166px);
                    y: parent.height - 8px;
                    width: root.compact-layout ? 54px : 64px;
                    height: 2px;
                    background: ThemeTokens.carmine.with-alpha(0.72);
                }

                Rectangle {
                    x: parent.width - (root.compact-layout ? 88px : 98px);
                    y: parent.height - 12px;
                    width: root.compact-layout ? 36px : 42px;
                    height: 2px;
                    background: ThemeTokens.copal.with-alpha(0.74);
                }

                Rectangle {
                    x: 16px;
                    y: root.compact-layout ? 20px : 14px;
                    width: root.compact-layout ? 48px : 44px;
                    height: root.compact-layout ? 48px : 44px;
                    border-radius: ThemeTokens.radius-large;
                    background: ThemeTokens.surface;
                    border-width: 1px;
                    border-color: ThemeTokens.stroke;

                    Image {
                        x: root.compact-layout ? 5px : 4px;
                        y: root.compact-layout ? 5px : 4px;
                        width: root.compact-layout ? 38px : 36px;
                        height: root.compact-layout ? 38px : 36px;
                        source: ThemeTokens.dark ? @image-url("../../assets/holoForensicsLogoDark.svg") : @image-url("../../assets/holoForensicsLogo.svg");
                    }
                }

                SectionLabel {
                    x: root.compact-layout ? 76px : 72px;
                    y: root.compact-layout ? 18px : 12px;
                    width: max(120px, ((parent.width - (root.compact-layout ? 152px : 160px)) / 2) - (root.compact-layout ? 88px : 84px));
                    height: 14px;
                    text: root.collection-host-platform == "" ? "Host metadata unavailable" : root.collection-host-platform;
                    color: ThemeTokens.muted;
                }

                Text {
                    x: root.compact-layout ? 76px : 72px;
                    y: root.compact-layout ? 30px : 22px;
                    width: max(140px, ((parent.width - (root.compact-layout ? 152px : 160px)) / 2) - (root.compact-layout ? 88px : 84px));
                    height: 28px;
                    text: "Holo Forensics";
                    color: ThemeTokens.hero-foreground;
                    font-family: "Tomorrow";
                    font-size: root.compact-layout ? 24px : 23px;
                    font-weight: 100;
                    vertical-alignment: center;
                    overflow: elide;
                }

                Text {
                    x: root.compact-layout ? 76px : 72px;
                    y: root.compact-layout ? 58px : 48px;
                    width: max(140px, ((parent.width - (root.compact-layout ? 152px : 160px)) / 2) - (root.compact-layout ? 88px : 84px));
                    height: 16px;
                    text: root.collection-host-hardware == "" ? "CPU and memory details unavailable." : root.collection-host-hardware;
                    color: ThemeTokens.muted;
                    font-family: "Figtree";
                    font-size: 12px;
                    font-weight: 400;
                    vertical-alignment: center;
                    overflow: elide;
                }

                HorizontalLayout {
                    x: (parent.width - (root.compact-layout ? 152px : 160px)) / 2;
                    y: root.header-mode-row-y;
                    width: root.compact-layout ? 152px : 160px;
                    height: 28px;
                    spacing: 8px;

                    MiniModeButton {
                        width: 76px;
                        label: "Collect";
                        active: root.active-page == 0;
                        animation-pulse: root.mode-switch-pulse;
                        enabled: !root.busy;
                        clicked => {
                            root.page-viewport-y = 0px;
                            root.switch-page-requested(0);
                        }
                    }

                    MiniModeButton {
                        width: 76px;
                        label: "Parse";
                        active: root.active-page == 1;
                        animation-pulse: root.mode-switch-pulse;
                        enabled: !root.busy;
                        clicked => {
                            root.page-viewport-y = 0px;
                            root.switch-page-requested(1);
                        }
                    }
                }

                HorizontalLayout {
                    x: parent.width - (root.compact-layout ? 204px : 222px);
                    y: root.header-action-row-y;
                    width: root.compact-layout ? 188px : 206px;
                    height: 38px;
                    spacing: 8px;

                    GhostButton {
                        width: root.compact-layout ? 82px : 88px;
                        enabled: !root.busy;
                        foreground: ThemeTokens.hero-foreground;
                        fill: ThemeTokens.panel;
                        hover-fill: ThemeTokens.accent-soft;
                        stroke: ThemeTokens.stroke;
                        label: "About";
                        clicked => { root.open-about-requested(); }
                    }

                    GhostButton {
                        width: root.compact-layout ? 98px : 110px;
                        enabled: !root.busy;
                        foreground: ThemeTokens.hero-foreground;
                        fill: ThemeTokens.panel;
                        hover-fill: ThemeTokens.accent-soft;
                        stroke: ThemeTokens.stroke;
                        label: "Settings";
                        clicked => { root.open-settings-requested(); }
                    }
                }
            }

            ParseResourcePanel {
                horizontal-stretch: 1;
                height: root.resource-card-height;
                cpu-value: root.parse-resource-cpu-value;
                memory-value: root.parse-resource-memory-value;
                io-value: root.parse-resource-io-value;
                cpu-detail: root.parse-resource-cpu-detail;
                memory-detail: root.parse-resource-memory-detail;
                io-detail: root.parse-resource-io-detail;
                status-text: root.parse-status;
                io-targets: root.parse-resource-io-targets;
                io-target-index <=> root.parse-resource-io-target-index;
                busy: root.busy;
            }

            CardPanel {
                horizontal-stretch: 1;
                height: root.setup-card-height;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding: 12px;
                    spacing: 6px;

                    SectionLabel { text: "PARSE SETUP"; }

                    HelperText {
                        horizontal-stretch: 1;
                        height: 18px;
                        text: "Inspect a collection zip to preview parser plans, or parse immediately to run every supported offline parser into the selected output folder.";
                    }

                    HorizontalLayout {
                        height: 16px;
                        spacing: 10px;

                        SectionLabel { text: "COLLECTION ZIP"; }

                        InfoLine {
                            horizontal-stretch: 1;
                            text: root.parse-archive-path == "" ? "Browse starts in your collection package folder until a zip is selected." : "Inspect refreshes the parser plan preview, but Parse can run immediately against the selected zip.";
                        }
                    }

                    HorizontalLayout {
                        height: 38px;
                        spacing: 10px;

                        ReadOnlyField {
                            horizontal-stretch: 1;
                            value: root.parse-archive-path;
                            placeholder: "Collection zip";
                        }

                        GhostButton {
                            width: 92px;
                            enabled: !root.busy;
                            label: "Browse";
                            clicked => { root.browse-parse-archive-requested(); }
                        }

                        GhostButton {
                            width: 96px;
                            enabled: !root.busy && root.parse-archive-path != "";
                            label: root.parse-inspecting ? "Inspecting..." : "Inspect";
                            clicked => {
                                root.page-viewport-y = 0px;
                                root.inspect-archive-requested();
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 16px;
                        spacing: 10px;

                        SectionLabel { text: "OUTPUT"; }

                        InfoLine {
                            horizontal-stretch: 1;
                            text: "Choose where extracted evidence, parser output, and the manifest will be written.";
                        }
                    }

                    HorizontalLayout {
                        height: 38px;
                        spacing: 10px;

                        ReadOnlyField {
                            horizontal-stretch: 1;
                            value: root.parse-output-path;
                            placeholder: "Parse output folder";
                        }

                        GhostButton {
                            width: 128px;
                            enabled: !root.busy;
                            label: "Browse Output";
                            clicked => { root.browse-parse-output-requested(); }
                        }

                        PrimaryButton {
                            width: 128px;
                            enabled: !root.busy && root.parse-archive-path != "";
                            fill: ThemeTokens.risk;
                            hover-fill: ThemeTokens.risk-hover;
                            stroke: ThemeTokens.risk.with-alpha(0.74);
                            label: root.parse-running ? "Parsing..." : "Parse";
                            clicked => {
                                root.page-viewport-y = 0px;
                                root.run-parse-requested();
                            }
                        }
                    }
                }
            }

            CardPanel {
                horizontal-stretch: 1;
                height: root.status-card-height;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding: 12px;
                    spacing: 8px;

                    HorizontalLayout {
                        height: 18px;
                        spacing: 12px;

                        SectionLabel { text: "PARSE STATUS"; }

                        Rectangle { horizontal-stretch: 1; }

                        Text {
                            text: root.parse-status;
                            color: ThemeTokens.muted;
                            font-family: "Figtree";
                            font-size: 12px;
                            font-weight: 400;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }

                    if !root.compact-layout : split-area := Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        clip: true;

                        private property <length> clamped-detail-width: max(
                            root.status-detail-min-width,
                            min(
                                root.parse-detail-width,
                                self.width - root.status-master-min-width - root.status-split-handle-width
                            )
                        );
                        private property <length> plan-list-width: max(
                            0px,
                            self.width - self.clamped-detail-width - root.status-split-handle-width
                        );

                        Rectangle {
                            x: 0px;
                            y: 0px;
                            width: split-area.plan-list-width;
                            height: parent.height;
                            background: transparent;

                            VerticalLayout {
                                width: parent.width;
                                height: parent.height;
                                spacing: 8px;

                                HorizontalLayout {
                                    height: 18px;
                                    spacing: 8px;

                                    Text {
                                        horizontal-stretch: 1;
                                        text: "Detected Parser Plans";
                                        color: ThemeTokens.text;
                                        font-family: "Tomorrow";
                                        font-size: 18px;
                                        font-weight: 300;
                                        vertical-alignment: center;
                                    }
                                }

                                HelperText {
                                    horizontal-stretch: 1;
                                    height: root.has-detected-artifacts ? 34px : 18px;
                                    text: root.busy ? "Current rows highlight active parser groups as the workflow advances." : root.has-detected-artifacts ? "Use the list to review or change supported parser groups before you start." : "Inspect a collection zip to preview supported parser groups, or parse immediately with full supported coverage.";
                                }

                                if root.has-detected-artifacts : ScrollView {
                                    vertical-stretch: 1;

                                    VerticalLayout {
                                        width: max(0px, parent.width - 10px);
                                        alignment: start;
                                        spacing: 6px;

                                        for item[index] in root.detected-artifacts : ParsePlanRow {
                                            horizontal-stretch: 1;
                                            title: item.title;
                                            subtitle: item.subtitle;
                                            detail: item.detail;
                                            status: item.status;
                                            selected: item.selected;
                                            active: item.active;
                                            tone: item.tone;
                                            enabled: !root.busy;
                                            toggled => { root.toggle-detected_artifact(index); }
                                        }
                                    }
                                }

                                if !root.has-detected-artifacts : InfoLine {
                                    horizontal-stretch: 1;
                                    height: 18px;
                                    text: root.busy ? "Resolving supported artifact groups..." : "No supported artifact groups detected yet.";
                                }
                            }
                        }

                        split-divider := Rectangle {
                            x: split-area.plan-list-width;
                            y: 0px;
                            width: root.status-split-handle-width;
                            height: parent.height;
                            background: transparent;

                            Rectangle {
                                x: (parent.width - self.width) / 2;
                                y: 10px;
                                width: 2px;
                                height: max(0px, parent.height - 20px);
                                border-radius: 1px;
                                background: split-touch.pressed ? ThemeTokens.primary.with-alpha(0.55) : split-touch.has-hover ? ThemeTokens.primary.with-alpha(0.34) : ThemeTokens.stroke;
                            }

                            Rectangle {
                                x: 2px;
                                y: max(8px, (parent.height - self.height) / 2);
                                width: max(0px, parent.width - 4px);
                                height: 42px;
                                border-radius: 6px;
                                background: split-touch.pressed ? ThemeTokens.primary.with-alpha(0.16) : split-touch.has-hover ? ThemeTokens.accent-soft : transparent;
                            }

                            split-touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: ew-resize;

                                pointer-event(event) => {
                                    if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                                        root.status-split-drag-start-width = split-area.clamped-detail-width;
                                        root.status-split-drag-start-pointer-x = split-touch.absolute-position.x + split_touch.pressed-x;
                                    }
                                }

                                moved => {
                                    root.parse-detail-width = max(
                                        root.status-detail-min-width,
                                        min(
                                            root.status-split-drag-start-width - ((split_touch.absolute-position.x + split_touch.mouse_x) - root.status-split-drag-start-pointer-x),
                                            split-area.width - root.status-master-min-width - root.status-split-handle-width
                                        )
                                    );
                                }
                            }
                        }

                        ParseStatusDetailPanel {
                            x: split-area.plan-list-width + root.status-split-handle-width;
                            y: 0px;
                            width: split-area.clamped-detail-width;
                            height: parent.height;
                            phase: root.busy ? "ACTIVE" : root.has-detected-artifacts ? "READY" : "IDLE";
                            current-status: root.parse-status;
                            summary: root.parse-summary;
                            progress-value: root.parse-progress-value;
                            coverage: root.busy ? "Left-side rows track the parser group currently being executed." : root.has-detected-artifacts ? "Use the list on the left to include or exclude detected parser groups." : "Inspect to preview parser groups, or parse immediately to run every supported offline parser.";
                        }
                    }

                    if root.compact-layout : VerticalLayout {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        spacing: 8px;

                        VerticalLayout {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            spacing: 8px;

                            HorizontalLayout {
                                height: 18px;
                                spacing: 8px;

                                Text {
                                    horizontal-stretch: 1;
                                    text: "Detected Parser Plans";
                                    color: ThemeTokens.text;
                                    font-family: "Tomorrow";
                                    font-size: 18px;
                                    font-weight: 300;
                                    vertical-alignment: center;
                                }
                            }

                            HelperText {
                                horizontal-stretch: 1;
                                height: root.has-detected-artifacts ? 34px : 18px;
                                text: root.busy ? "Current rows highlight active parser groups as the workflow advances." : root.has-detected-artifacts ? "Use the list to review or change supported parser groups before you start." : "Inspect a collection zip to preview supported parser groups, or parse immediately with full supported coverage.";
                            }

                            if root.has-detected-artifacts : ScrollView {
                                vertical-stretch: 1;

                                VerticalLayout {
                                    width: max(0px, parent.width - 10px);
                                    alignment: start;
                                    spacing: 6px;

                                    for item[index] in root.detected-artifacts : ParsePlanRow {
                                        horizontal-stretch: 1;
                                        title: item.title;
                                        subtitle: item.subtitle;
                                        detail: item.detail;
                                        status: item.status;
                                        selected: item.selected;
                                        active: item.active;
                                        tone: item.tone;
                                        enabled: !root.busy;
                                        toggled => { root.toggle-detected-artifact(index); }
                                    }
                                }
                            }

                            if !root.has-detected-artifacts : InfoLine {
                                horizontal-stretch: 1;
                                height: 18px;
                                text: root.busy ? "Resolving supported artifact groups..." : "No supported artifact groups detected yet.";
                            }
                        }

                        ParseStatusDetailPanel {
                            horizontal-stretch: 1;
                            height: 228px;
                            phase: root.busy ? "ACTIVE" : root.has-detected-artifacts ? "READY" : "IDLE";
                            current-status: root.parse-status;
                            summary: root.parse-summary;
                            progress-value: root.parse-progress-value;
                            coverage: root.busy ? "Rows above track the parser group currently being executed." : root.has-detected-artifacts ? "Use the list above to include or exclude detected parser groups." : "Inspect to preview parser groups, or parse immediately to run every supported offline parser.";
                        }
                    }
                }
            }

            CardPanel {
                horizontal-stretch: 1;
                height: root.console-card-height;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding: 12px;
                    spacing: root.console-expanded ? 8px : 0px;

                    HorizontalLayout {
                        height: 24px;
                        spacing: 12px;

                        Text {
                            text: "Console";
                            color: ThemeTokens.text;
                            font-family: "Tomorrow";
                            font-size: 18px;
                            font-weight: 300;
                            vertical-alignment: center;
                        }

                        Rectangle { horizontal-stretch: 1; }

                        GhostButton {
                            width: 86px;
                            height: 24px;
                            label: root.console-expanded ? "Collapse" : "Expand";
                            clicked => { root.console-expanded = !root.console-expanded; }
                        }
                    }

                    InfoLine {
                        horizontal-stretch: 1;
                        text: "Live console tail from ~/.holo-forensics/holo-forensics.log.";
                        height: 16px;
                        vertical-alignment: center;
                        visible: root.console-expanded;
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        border-radius: ThemeTokens.radius-medium;
                        border-width: 1px;
                        border-color: ThemeTokens.stroke;
                        background: ThemeTokens.console-surface;
                        clip: true;
                        visible: root.console-expanded;

                        console-scroll := ScrollView {
                            x: 0px;
                            y: 0px;
                            width: parent.width;
                            height: parent.height;
                            viewport-width: self.visible-width;
                            viewport-height: max(self.visible-height, console-text.preferred-height + 20px);

                            Rectangle {
                                width: console-scroll.visible-width;
                                height: console-scroll.viewport-height;
                                background: transparent;

                                console-text := Text {
                                    x: 12px;
                                    y: 10px;
                                    width: max(0px, console-scroll.visible-width - 24px);
                                    text: root.parse-log == "" ? "No console output yet." : root.parse-log;
                                    color: #E2E7EF;
                                    font-family: "Tomorrow";
                                    font-size: 11px;
                                    font-weight: 400;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }
        }
}